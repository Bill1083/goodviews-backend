# goodviews-server/.env.example

# Flask
FLASK_ENV=development
SECRET_KEY=replace_with_a_long_random_string_at_least_32_chars

# TMDB — get from https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_v3_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3

# Supabase — Project Settings → API → service_role key (NEVER expose to frontend)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Redis — Render provides this URL; use redis://localhost:6379 for local dev
REDIS_URL=redis://localhost:6379

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173
